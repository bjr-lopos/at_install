lclDir=`dirname $0`
source $lclDir/local_cfg
#GRANT FILE ON *.* TO 'lopos'@'localhost';
if [ -z "$1" ] | [ -z "$2" ]; then
	echo please invoke like "$0 startDateTime endDateTime"
	echo "example: $0 2021-12-25 00:00:00 2021-12-25 10:00:00"
	exit
fi

startDateTime=$1
endDateTime=$2

resFile="/tmp/grab_$startDateTime"_"$endDateTime@`date`.csv"
resFile=`echo "$resFile" | sed -e 's/ /_/g'`
#echo $resFile
sql=`cat << EndOfMessage
select 
	addr&0xFFF, x, y, updated 
from 
	position
where
	numHyperbola > 2
	and 
	updated > "$startDateTime"
	and
	updated < "$endDateTime"
order by 4
INTO OUTFILE 
	"$resFile"
FIELDS ENCLOSED BY '\"'  
TERMINATED BY ';'  
ESCAPED BY '\"'  
LINES TERMINATED BY '\r\n';
EndOfMessage`
#mysql --local-infile -u$USERLOGIN -p$USERPASS $TARGET_DB -e "$sql"
mysql -u$USERLOGIN -p$USERPASS $TARGET_DB -e "$sql"
echo results should be in $resFile


