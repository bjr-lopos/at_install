delay=$((15*60))
if [ ! -z "$1" ]; then
	delay="$1"
        delay="$1"
fi
echo will use delay $delay
#sleep 1
source $lclDir/local_cfg
sql=`cat << EndOfMessage
select
	devA & 0xFFF as devA,
	devB & 0xFFF as debB,
	min(dist),
	avg(dist),
	max(dist),
	count(*)

from 
	twr
where
	TIMESTAMPDIFF(HOUR,updated,now()) < 3
group 
	by devA, devB
order
	by 1
EndOfMessage`
mysql -u$USERLOGIN -p$USERPASS $TARGET_DB -e "$sql" 
